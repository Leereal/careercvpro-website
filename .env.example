# Supabase Configuration (for database/leads tracking)
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# MinIO Configuration (for file uploads)
MINIO_ENDPOINT=storage.cvevolve.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_CV_LEADS_BUCKET=cv-leads
MINIO_BASE_URL=https://storage.cvevolve.com

# Optional: Analytics
# Plausible Analytics Domain
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=careercvpro.co.za
